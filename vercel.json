{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/(.*\\.(js|css|png|ico|svg|woff|woff2|ttf|eot|map))", "dest": "/website/$1" },
    { "src": "/(.*)", "dest": "/website/index.html" }
  ]
}
